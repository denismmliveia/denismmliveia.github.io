rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil de usuario: cualquier autenticado puede leer, solo el propietario puede escribir
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasAll(['displayName', 'photoUrl'])
        && !('activeQrToken' in request.resource.data);
    }

    // Links: solo participantes pueden leer, solo Cloud Functions escriben
    match /links/{linkId} {
      allow read: if request.auth != null &&
        (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
      allow write: if false;
    }

    match /links/{linkId}/messages/{msgId} {
      function isLinkParticipant() {
        let link = get(/databases/$(database)/documents/links/$(linkId)).data;
        return request.auth.uid == link.userA || request.auth.uid == link.userB;
      }

      function isLinkActive() {
        let link = get(/databases/$(database)/documents/links/$(linkId)).data;
        return link.status == 'linked';
      }

      allow read: if request.auth != null && isLinkParticipant();

      allow create: if request.auth != null
        && isLinkParticipant()
        && isLinkActive()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.createdAt == request.time;

      // viewedBy and deletedFromStorage are only updated by Cloud Functions (Admin SDK bypasses rules)
      allow update, delete: if false;
    }

    // Recuerdos: solo el propietario puede leer, solo Cloud Functions escriben
    match /memories/{uid}/cards/{memoryId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Bloqueados: solo el propietario puede leer, solo Cloud Functions escriben
    match /blocks/{uid}/blocked/{blockedUid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Reportes: solo Cloud Functions escriben, nadie lee desde cliente
    match /reports/{reportId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
