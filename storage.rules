rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos — owner writes (JPEG/PNG only), authenticated users read
    match /profile_photos/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && (request.resource.contentType == 'image/jpeg'
                       || request.resource.contentType == 'image/png');
    }

    // Chat photos — only Cloud Functions (admin SDK) access these
    // Client uses signed URLs generated by Cloud Functions
    match /chat/{allPaths=**} {
      allow read, write: if false;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
